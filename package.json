{
  "name": "jw-daily-text",
  "author": "JW Daily Text Contributors",
  "version": "2.0.4",
  "description": "Daily Text app for Pebble smartwatches. Displays Jehovah's Witnesses daily Bible scripture with commentary in any language.",
  "keywords": ["pebble-app", "jw", "daily-text"],
  "private": true,
  "dependencies": {},
  "pebble": {
    "displayName": "Daily Text",
    "uuid": "ecca2ec3-068b-4cff-a500-a27184c1b841",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": ["emery"],
    "watchapp": {
      "watchface": false
    },
    "capabilities": ["configurable"],
    "messageKeys": [
      "action",
      "date",
      "ref",
      "text",
      "commentary",
      "error",
      "language",
      "lib",
      "year",
      "month",
      "month_entry_date",
      "month_entry_ref",
      "month_entry_text",
      "month_entry_commentary",
      "month_total",
      "month_index",
      "cache_days",
      "rsconf",
      "action_sync_range",
      "start_date",
      "end_date"
    ],
    "resources": {
      "media": []
    }
  }
}
